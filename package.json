{
  "name": "padel-club-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@padel/web",
    "dev:api": "npm run dev --workspace=@padel/api",
    "db:generate": "npm run generate --workspace=@padel/db",
    "db:migrate": "npm run migrate:dev --workspace=@padel/db",
    "db:deploy": "npm run migrate:deploy --workspace=@padel/db",
    "db:seed": "npm run seed --workspace=@padel/db",
    "postinstall": "echo skipping-postinstall"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "pg": "^8.20.0"
  }
}
